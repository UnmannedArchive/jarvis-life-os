# Supabase (optional — app runs in guest mode without these)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Gemini — powers BOTH the Smart Inbox classifier (/api/classify-input)
# and "Plan my day" ordering (/api/plan-day). Free tier, no credit card:
# https://aistudio.google.com/apikey
# Note: on managed/edu Google accounts use gemini-2.5-flash — 2.0-flash's free
# tier may be disabled (HTTP 429 "limit: 0"). Without this key, the planner falls
# back to built-in local ordering; the Smart Inbox shows a not-configured error.
GEMINI_API_KEY=

# Optional model overrides (defaults shown):
# CLASSIFIER_MODEL=gemini-2.5-flash
# PLANNER_MODEL=gemini-2.5-flash

# Anthropic — no longer required. The Smart Inbox used to classify with Claude;
# it now uses Gemini. Leave unset unless you switch the routes back to Anthropic.
# ANTHROPIC_API_KEY=

# WHOOP integration (optional — Settings → WHOOP is hidden/disabled without these).
# 1. Register an app at https://developer.whoop.com (free).
# 2. Set the redirect URI in the WHOOP app to EXACTLY match the value below.
# The client id + redirect URI are public (NEXT_PUBLIC_*, used by the browser to
# build the authorize URL); the client SECRET stays server-side and is only used
# by /api/whoop/exchange and /api/whoop/refresh.
NEXT_PUBLIC_WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
# Local dev (note port 3001); for prod use https://<your-domain>/whoop/callback
NEXT_PUBLIC_WHOOP_REDIRECT_URI=http://localhost:3001/whoop/callback

# WHOOP instant push (webhooks) — OPTIONAL, only needed for "live even when the
# app is closed". Requires the app deployed at a public HTTPS URL.
# 1. Add this Supabase service-role key (Project Settings → API). SERVER-ONLY —
#    never expose it; it bypasses RLS to read whoop_tokens + write whoop_data.
SUPABASE_SERVICE_ROLE_KEY=
# 2. In the WHOOP app, set the webhook URL to https://<your-domain>/api/whoop/webhook
#    Webhooks can't reach localhost — only works on the deployed site.

# Google Calendar WRITE access (optional — lets the WHOOP Coach add recovery-aware
# blocks to your real calendar). Separate from the read-only iCal link.
# Create an OAuth 2.0 Web client at https://console.cloud.google.com/apis/credentials
# with the Calendar API enabled + scope calendar.events. Client id + redirect are
# public; the secret stays server-side (used by /api/gcal/exchange + /api/gcal/refresh).
# Note: a USC edu Workspace may block creating the OAuth client — use a personal Google account.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3001/gcal/callback
